{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "fs:scope",
      "allow": ["$APPDATA/**"]
    },
    "fs:allow-read-file",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-save",
    "clipboard-manager:allow-write-text",
    {
      "identifier": "sql:allow-load",
      "allow": [{ "url": "sqlite:paperlens.db" }]
    },
    "sql:allow-select",
    "sql:allow-execute",
    "sql:allow-close"
  ]
}
